# BIRD meshctl managed configuration for {{ .Node.Name }}
# Generated by meshctl — do not edit manually
# Compatible with BIRD 2.x (OSPFv3 requires separate instances per AF)

# Loopback /32 stub — advertised into OSPF
protocol static meshctl_lo4 {
    ipv4 { table {{ .Global.IGPTable4 }}; };
    route {{ .Node.Loopback }}/32 via "lo";
}

{{ if .Fe80Links -}}
# OSPFv3 IPv4 AF (RFC 5838) — fe80 neighbor sessions, carries IPv4 routes.
# Instance ID 64 per RFC 5838 §2.1 (IPv4 unicast AF).
# Requires 169.254.x.x PTP addresses on interfaces for IPv4 nexthop resolution.
protocol ospf v3 meshctl_ospf3_v4 {
    ipv4 {
        table {{ .Global.IGPTable4 }};
        import all;
        export all;
    };
    instance id 64;
    area {{ .Global.OSPFArea }} {
        {{- range .Fe80Links }}
        interface "{{ ifaceName (.PeerName $.Node.Name) }}" {
            type pointopoint;
            hello {{ $.Global.OSPFHello }};
            dead {{ $.Global.OSPFDead }};
            cost {{ peerCost $.PeerCosts (.PeerName $.Node.Name) }};
        };
        {{- end }}
    };
}

# OSPFv3 IPv6 AF — fe80 neighbor sessions, carries IPv6 routes.
protocol ospf v3 meshctl_ospf3_v6 {
    ipv6 {
        table {{ .Global.IGPTable6 }};
        import all;
        export all;
    };
    area {{ .Global.OSPFArea }} {
        {{- range .Fe80Links }}
        interface "{{ ifaceName (.PeerName $.Node.Name) }}" {
            type pointopoint;
            hello {{ $.Global.OSPFHello }};
            dead {{ $.Global.OSPFDead }};
            cost {{ peerCost $.PeerCosts (.PeerName $.Node.Name) }};
        };
        {{- end }}
    };
}
{{ end -}}

{{ if .V4LLLinks -}}
# OSPFv2 for 169.254.x.x links (RouterOS / static peers)
protocol ospf v2 meshctl_ospf2 {
    ipv4 {
        table {{ .Global.IGPTable4 }};
        import all;
        export all;
    };
    area {{ .Global.OSPFArea }} {
        {{- range .V4LLLinks }}
        interface "{{ ifaceName (.PeerName $.Node.Name) }}" {
            type pointopoint;
            hello {{ $.Global.OSPFHello }};
            dead {{ $.Global.OSPFDead }};
            cost {{ peerCost $.PeerCosts (.PeerName $.Node.Name) }};
        };
        {{- end }}
    };
}
{{ end -}}
